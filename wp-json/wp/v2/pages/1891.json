to Citizenship in 5 years.<\/p>\n                                <\/div>\n        \n        \n                <\/div>\n        <\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-da5842a e-con-full e-flex e-con e-parent\" data-id=\"da5842a\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-a7e803e e-flex e-con-boxed e-con e-child\" data-id=\"a7e803e\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-0bd5bae elementor-widget__width-initial elementor-widget elementor-widget-heading\" data-id=\"0bd5bae\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Benefits - USA EB-5 Investor Visa<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-d9f5fee elementor-widget__width-initial elementor-widget elementor-widget-text-editor\" data-id=\"d9f5fee\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Avail the privileges and luxury lifestyle by living in the United States as a permanent resident.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-de7c8e1 e-flex e-con-boxed e-con e-child\" data-id=\"de7c8e1\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-028b500 e-grid e-con-full e-con e-child\" data-id=\"028b500\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div cla