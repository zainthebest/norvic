ent\/uploads\/2024\/02\/support-1.png\" class=\"attachment- size-\" alt=\"\" \/>                <\/div>\n          <\/div>\n                <div class=\"box-body\">\n                            <h3 class=\"elementskit-info-box-title\">\n                    Family Inclusive                 <\/h3>\n                        \t\t  \t<p>Includes family members, with no age limit, net worth, or educational background restrictions<\/p>\n                                <\/div>\n        \n        \n                <\/div>\n        <\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-479436a ekit-equal-height-enable elementor-invisible elementor-widget elementor-widget-elementskit-icon-box\" data-id=\"479436a\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;_animation&quot;:&quot;xpro-anim-mask-from-left&quot;,&quot;_animation_delay&quot;:1}\" data-widget_type=\"elementskit-icon-box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"ekit-wid-con\" >        <!-- link opening -->\n                <!-- end link opening -->\n\n        <div class=\"elementskit-infobox text-left text-left icon-top-align elementor-animation-  gradient-active  hover_from_left\">\n                            <div class=\"elementskit-box-header\">\n                <div class=\"elementskit-info-box-icon \">\n                    <img loading=\"lazy\" decoding=\"async\" width=\"64\" height=\"64\" src=\"https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/03\/peace-flag.png\" class=\"attachment- size-\" alt=\"\" \/>                <\/div>\n          <\/div>\n                <div class=\"box-body\">\n                            <h3 class=\"elementskit-info-box-title\">\n                    Pathway to Citizenship                <\/h3>\n                        \t\t  \t<p>Qualify for citizenship after three years of physical residency within five years, while enjoying the advantages of economic in