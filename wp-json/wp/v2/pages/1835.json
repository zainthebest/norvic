elementor-animation-  gradient-active  hover_from_left\">\n                            <div class=\"elementskit-box-header\">\n                <div class=\"elementskit-info-box-icon \">\n                    <img decoding=\"async\" width=\"64\" height=\"64\" src=\"https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/03\/calendar-1.png\" class=\"attachment- size-\" alt=\"\" \/>                <\/div>\n          <\/div>\n                <div class=\"box-body\">\n                        \t\t  \t<p>Invest in government-approved real estate, holding property for five years is must.<\/p>\n                                <\/div>\n        \n        \n                <\/div>\n        <\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-0098535 e-flex e-con-boxed e-con e-parent\" data-id=\"0098535\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-4f62ded e-con-full e-flex e-con e-child\" data-id=\"4f62ded\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-294b247 elementor-invisible elementor-widget elementor-widget-text-editor\" data-id=\"294b247\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;_animation&quot;:&quot;xpro-anim-mask-from-left&quot;}\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>1: A contribution of minimum $230,000 or more to the National Development Fund. (Non-Refundable)<\/p><p>2: A contribution to the University of the West Indies of minimum $260,000 for a family of 6. (Non-Refundable)<\/p><p>3: The Real Estate Investment of minimum $300,000 in a Govt-approved project. The applicant needs to hold the investment for 5 years. (Refunable)<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-f850081 elementor-widget elementor-widget-heading\" data-id=\"f850081\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Routes to Get Antigua and Barbuda Citizenship in 90 Days<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-109d4f4 e-con-full e-flex e-con e-child\" data-id=\"109d4f4\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-99a5bb2 elementor-widget elementor-widget-image\" data-id=\"99a5bb2\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img loading=\"lazy\" decoding=\"async\" width=\"800\" height=\"533\" src=\"https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/09\/daacb94022.jpg\" class=\"attachment-large size-large wp-image-8303\" alt=\"\" srcset=\"https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/09\/daacb94022.jpg 1000w, https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/09\/daacb94022-300x200.jpg 300w, https:\/\/forecastmigration.com\/wp-content\/uploads\/2024\/09\/daacb94022-768x511.jpg 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-da5842a e-con-full e-flex e-con e-parent\" data-id=\"da5842a\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-a7e803e e-flex e-con-boxed e-con e-child\" data-id=\"a7e803e\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&qu